# Etherscope — production env template.
# Copy this into Railway's "Variables" UI per-service. NEVER commit real values.
#
# On Railway you usually attach Postgres and Redis as plugins and they inject
# DATABASE_URL / REDIS_URL automatically. This file lists the individual vars
# our Pydantic Settings class reads — match them to whatever your platform
# provides.

# --- Postgres (injected by Railway Postgres plugin; split for local parity) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=

# --- External APIs (rotate any key that has ever been shared in chat / PRs) ---
ALCHEMY_API_KEY=
DUNE_API_KEY=
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=

# --- Dune query IDs ---
DUNE_QUERY_ID_EXCHANGE_FLOWS=0
DUNE_QUERY_ID_STABLECOIN_SUPPLY=0
DUNE_QUERY_ID_ONCHAIN_VOLUME=0
DUNE_QUERY_ID_ORDER_FLOW=0
DUNE_SYNC_INTERVAL_MIN=240
DUNE_ORDER_FLOW_INTERVAL_MIN=480

# --- Whale tracking ---
WHALE_ETH_THRESHOLD=100
WHALE_STABLE_THRESHOLD_USD=250000

# --- Alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SIGNING_SECRET=
ALERT_DEFAULT_COOLDOWN_MIN=15

# --- API access control (v1 polish) ---
# Long random token. Frontend must have VITE_API_TOKEN set to the same value.
API_AUTH_TOKEN=
# Exact origin of your frontend on Railway (or wherever it's hosted).
CORS_ORIGINS=https://your-frontend.up.railway.app

# --- App ---
APP_ENV=prod
LOG_LEVEL=INFO
