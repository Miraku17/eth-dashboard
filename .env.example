# Postgres
POSTGRES_USER=eth
POSTGRES_PASSWORD=eth
POSTGRES_DB=eth
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# External APIs
ALCHEMY_API_KEY=
# Optional: override the WS URL with a self-hosted node (e.g. ws://172.17.0.1:8546).
# When set, the realtime listener uses this and ignores ALCHEMY_API_KEY.
ALCHEMY_WS_URL=
# Self-hosted Lighthouse beacon API (optional). When set, the staking
# panel surfaces a live active-validator-count tile. Default Lighthouse
# HTTP port is 5052; use the docker-bridge host for cross-container reach.
# Example: BEACON_HTTP_URL=http://172.17.0.1:5052
BEACON_HTTP_URL=
DUNE_API_KEY=
ETHERSCAN_API_KEY=
COINGECKO_API_KEY=

# Arbitrum endpoints (post-v4 on-chain perps — GMX V2 listener).
# Reuse the same Alchemy key (Alchemy serves Arbitrum on the same subscription)
# or point at a self-hosted Arbitrum Nitro node. When unset, the
# arbitrum_realtime container starts in no-op mode (logs a warning, sleeps).
# Setup: see docs/arbitrum-setup.md.
ARBITRUM_WS_URL=
ARBITRUM_HTTP_URL=

# Dune query IDs (create queries from backend/dune/*.sql in the Dune UI and paste IDs here)
DUNE_QUERY_ID_EXCHANGE_FLOWS=0
DUNE_QUERY_ID_STABLECOIN_SUPPLY=0
DUNE_QUERY_ID_ONCHAIN_VOLUME=0
DUNE_QUERY_ID_ORDER_FLOW=0
DUNE_SYNC_INTERVAL_MIN=240
# Order-flow runs less often to stay under the free-tier credit budget.
DUNE_ORDER_FLOW_INTERVAL_MIN=480
# Dune query ID for the smart-money leaderboard (v2). When unset, the
# sync job is a no-op and the panel shows "no data yet".
DUNE_QUERY_ID_SMART_MONEY_LEADERBOARD=0
# Dune query ID for trade-size buckets (v2). SQL: backend/dune/volume_buckets.sql
DUNE_QUERY_ID_VOLUME_BUCKETS=0
# Dune query ID for ETH staking flows (v3-staking). SQL: backend/dune/staking_flows.sql
DUNE_QUERY_ID_STAKING_FLOWS=0
# Dune query ID for per-entity staking flow breakdown (Lido / Coinbase / etc.).
# SQL: backend/dune/staking_flows_by_entity.sql
DUNE_QUERY_ID_STAKING_FLOWS_BY_ENTITY=0
# Dune query ID for L1 ↔ L2 bridge flows (Arbitrum / Base / Optimism / zkSync).
# SQL: backend/dune/bridge_flows.sql
DUNE_QUERY_ID_BRIDGE_FLOWS=0

# Whale tracking (M3) — realtime Alchemy listener
# ETH native transfers >= this many ETH count as "whale"
WHALE_ETH_THRESHOLD=100
# Stablecoin (USDT/USDC/DAI) transfers >= this many USD count as "whale"
WHALE_STABLE_THRESHOLD_USD=250000

# Alerts (M4) — notifications
# Telegram: see docs/telegram-setup.md
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Webhook: HMAC-SHA256 signed with this secret (header: X-Etherscope-Signature)
WEBHOOK_SIGNING_SECRET=
# Default cooldown for price rules (minutes)
ALERT_DEFAULT_COOLDOWN_MIN=15

# --- Auth (single-account session login) ---
# Username for the dashboard login.
AUTH_USERNAME=admin
# argon2id hash. Generate with: cd backend && python -m app.scripts.hash_password
AUTH_PASSWORD_HASH=
# Set to "false" only for local http development; keep true in production.
SESSION_COOKIE_SECURE=true
# Cookie auth requires explicit origins (no "*").
CORS_ORIGINS=http://localhost:5173

# App
APP_ENV=dev
LOG_LEVEL=INFO
